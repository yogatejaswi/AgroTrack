{
  "name": "agrotrack",
  "version": "1.0.0",
  "private": true,
  "description": "Farm Equipment Rental & Asset Management System",
  "main": "server/server.js",
  "scripts": {
    "start": "node server/server.js",
    "server": "cd server && npm start",
    "frontend": "cd frontend && npm run dev",
    "dev": "concurrently \"npm run server\" \"npm run frontend\"",
    "build": "cd frontend && npm run build && cd ../client && npm run build"
  },
  "type": "module",
  "dependencies": {
    "axios": "^1.13.6",
    "bcryptjs": "^3.0.3",
    "concurrently": "^8.2.2",
    "cors": "^2.8.6",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.3",
    "mongodb-memory-server": "^11.0.1",
    "mongoose": "^9.2.4",
    "multer": "^2.1.1",
    "mysql2": "^3.12.0",
    "node-cron": "^4.2.1",
    "nodemailer": "^8.0.1",
    "twilio": "^5.12.2"
  }
}